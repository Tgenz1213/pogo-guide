{
  "name": "queue-consumer",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev --env-file ../../web/.dev.vars --persist-to ../../.wrangler/state/v3 --port 8787",
    "deploy": "wrangler deploy --env production",
    "deploy:preview": "wrangler deploy --env preview",
    "test": "vitest run",
    "test:integration": "vitest run tests/sanity-preview.integration.test.ts",
    "test:e2e:queue": "vitest run tests/preview-queue.e2e.integration.test.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pogo/shared-utils": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260714.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.7",
    "wrangler": "^4.94.0"
  }
}
