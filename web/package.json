  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.10.0",
  "scripts": {
    "build": "nuxt build",
    "build:cloudflare": "nuxt build",
    "dev": "nuxt dev",
    "deploy:cloudflare": "pnpm build:cloudflare && wrangler --cwd .cloudflare deploy",
    "generate": "nuxt generate",
    "preview": "pnpm run build && wrangler dev",
    "preview:cloudflare": "pnpm run build:cloudflare && wrangler --cwd .cloudflare dev",
    "postinstall": "nuxt prepare",
    "typegen": "sanity typegen generate",
