{
  "name": "web",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.10.0",
  "scripts": {
    "build": "nuxt build",
    "build:cloudflare": "nuxt build",
    "dev": "nuxt dev",
    "deploy:cloudflare": "pnpm build:cloudflare && wrangler deploy --env production",
    "deploy:cloudflare:preview": "pnpm build:cloudflare && wrangler deploy --config wrangler.test.jsonc",
    "d1:migrate:preview:local": "echo y | wrangler d1 migrations apply DB --local --persist-to ../.wrangler/state/v3",
    "generate": "nuxt generate",
    "preview": "pnpm run build && wrangler dev",
    "preview:cloudflare": "pnpm run build:cloudflare && pnpm run d1:migrate:preview:local && wrangler dev --persist-to ../.wrangler/state/v3 --port 8788",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxi typecheck",
    "typegen": "sanity typegen generate",
    "test": "pnpm run test:ui",
    "test:ui": "vitest run -c vitest.config.ts",
    "test:server": "vitest run -c vitest.server.config.ts",
    "test:server:ci": "pnpm run build:cloudflare && vitest run -c vitest.server.config.ts",
    "test:ci": "pnpm run test:ui && pnpm run test:server:ci",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "deploy": "pnpm run build && wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@nuxtjs/robots": "^6.1.2",
    "@nuxtjs/sanity": "^2.3.0",
    "@nuxtjs/sitemap": "^8.2.2",
    "@nuxtjs/turnstile": "^1.1.3",
    "@pogo/shared-utils": "workspace:*",
    "@portabletext/vue": "^1.0.14",
    "@sentry/nuxt": "^10.53.1",
    "@tiptap/starter-kit": "^3.27.4",
    "@tiptap/vue-3": "^3.26.1",
    "drizzle-orm": "^0.45.2",
    "nuxt": "^4.4.8",
    "nuxt-auth-utils": "^0.5.29",
    "ofetch": "^1.5.1",
    "ufo": "^1.6.4",
    "vue": "^3.5.40",
    "vue-router": "^5.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@cloudflare/workers-types": "^5.20260713.1",
    "@nuxt/a11y": "1.0.0-alpha.1",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/color-mode": "^4.0.1",
    "@playwright/test": "^1.60.0",
    "@portabletext/types": "^4.0.2",
    "@sanity/cli": "^7.7.1",
    "@sanity/client": "^7.22.0",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/ui": "^4.1.7",
    "@vue/test-utils": "^2.4.11",
    "drizzle-kit": "^0.31.10",
    "h3": "1.15.11",
    "nitro-cloudflare-dev": "^0.2.2",
    "tailwindcss": "4.3.1",
    "vitest": "^4.1.10",
    "wrangler": "^4.94.0"
  }
}
