    "@nuxtjs/sitemap": "^8.0.15",
    "@nuxtjs/turnstile": "^1.1.3",
    "@portabletext/vue": "^1.0.14",
    "@sanity/schema": "^5.26.0",
    "@sentry/nuxt": "^10.53.1",
    "nuxt": "^4.4.6",
    "ofetch": "^1.5.1",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nuxt/a11y": "1.0.0-alpha.1",
