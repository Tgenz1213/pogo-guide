{
  "name": "web",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.10.0",
  "scripts": {
    "build": "nuxt build",
    "build:cloudflare": "nuxt build",
    "dev": "nuxt dev",
    "deploy:cloudflare": "pnpm build:cloudflare && wrangler --cwd .cloudflare deploy",
    "generate": "nuxt generate",
    "preview": "pnpm run build && wrangler dev",
    "preview:cloudflare": "pnpm run build:cloudflare && wrangler --cwd .cloudflare dev",
    "postinstall": "nuxt prepare",
    "typegen": "sanity typegen generate",
    "test": "pnpm run test:ui",
    "test:ui": "vitest run -c vitest.config.ts",
    "test:server": "vitest run -c vitest.server.config.ts",
    "test:server:ci": "pnpm run build:cloudflare && vitest run -c vitest.server.config.ts",
    "test:ci": "pnpm run test:ui && pnpm run test:server:ci",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "deploy": "pnpm run build && wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@nuxtjs/robots": "^6.0.8",
    "@nuxtjs/sanity": "^2.3.0",
    "@nuxtjs/sitemap": "^8.0.15",
    "@nuxtjs/turnstile": "^1.1.3",
    "@portabletext/vue": "^1.0.14",
    "@sentry/nuxt": "^10.53.1",
    "@tiptap/starter-kit": "^3.23.6",
    "@tiptap/vue-3": "^3.23.6",
    "drizzle-orm": "^0.45.2",
    "nuxt": "^4.4.6",
    "nuxt-auth-utils": "^0.5.29",
    "ofetch": "^1.5.1",
    "sanitize-html": "^2.17.4",
    "ufo": "^1.6.4",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.9",
    "@nuxt/a11y": "1.0.0-alpha.1",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@playwright/test": "^1.60.0",
    "@portabletext/types": "^4.0.2",
    "@sanity/cli": "^6.6.0",
    "@sanity/client": "^7.22.0",
    "@types/node": "^25.9.1",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/ui": "^4.1.7",
    "@vue/test-utils": "^2.4.10",
    "drizzle-kit": "^0.31.10",
    "nitro-cloudflare-dev": "^0.2.2",
    "vitest": "^4.1.7",
    "wrangler": "^4.94.0"
  }
}
