{
  "name": "pogo-guide-monorepo",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.16.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "knip": "^6.16.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.4"
  },
  "scripts": {
    "prepare": "husky",
    "knip": "knip",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint . && pnpm --dir studio lint",
    "lint:fix": "eslint . --fix && pnpm --dir studio lint:fix"
  },
  "lint-staged": {
    "*.{js,ts,mjs}": [
      "prettier --write",
      "eslint --fix --ignore-pattern studio/** --no-warn-ignored"
    ],
    "web/**/*.{js,ts,vue,mjs}": [
      "prettier --write",
      "eslint --fix",
      "pnpm --filter web run test --"
    ],
    "studio/**/*.{js,ts,mjs}": [
      "prettier --write",
      "pnpm --dir studio exec eslint --fix"
    ],
    "packages/shared-utils/**/*.{js,ts}": [
      "prettier --write",
      "eslint --fix",
      "pnpm --filter @pogo/shared-utils run test --"
    ],
    "packages/queue-consumer/**/*.{js,ts}": [
      "prettier --write",
      "eslint --fix",
      "pnpm --filter queue-consumer run test --"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
