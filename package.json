{
  "name": "pogo-guide-monorepo",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "knip": "^6.14.2",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.1"
  },
  "scripts": {
    "prepare": "husky",
    "knip": "knip",
    "lint": "eslint . && pnpm --dir studio lint",
    "lint:fix": "eslint . --fix && pnpm --dir studio lint:fix"
  },
  "lint-staged": {
    "*.{js,ts,mjs}": [
      "prettier --write",
      "eslint --fix --ignore-pattern studio/** --no-warn-ignored",
      "pnpm --filter web run test"
    ],
    "web/**/*.{js,ts,vue,mjs}": [
      "prettier --write",
      "eslint --fix",
      "pnpm --filter web run test"
    ],
    "studio/**/*.{js,ts,mjs}": [
      "prettier --write",
      "pnpm --dir studio exec eslint --fix"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
